---
import { Image } from 'astro:assets';
import latinReporter from '../assets/latin_reporter.png';
import complianceOfficer from '../assets/compliance_officer.png';
---
<section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-32 overflow-hidden bg-white">
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Top Hero Info -->
    <div class="text-center max-w-6xl mx-auto mb-16 sm:mb-20">

      <!-- Short Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 leading-[1.15] text-balance mb-6">
        El canal de denuncias confiable y 100% privado.
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg lg:text-xl text-slate-700 max-w-5xl mx-auto mb-8 sm:mb-10 text-pretty leading-relaxed">
        Activamos tu canal anónimo e independiente en 24 horas. Una solución integral que une inteligencia artificial y especialistas dedicados para mitigar riesgos y transformar tu cumplimiento en una ventaja competitiva.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#demo" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-900 bg-almond-cream hover:bg-almond-cream-hover rounded-md shadow-sm hover:shadow-md text-center transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream">
          Agendar una Demo
        </a>
        <a href="#seguridad" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-850 hover:text-slate-950 bg-white hover:bg-floral-white border border-dust-grey hover:border-slate-400 rounded-md text-center transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream">
          Cómo protegemos la identidad
        </a>
      </div>
    </div>

    <!-- Double panel widget visual at full width (no grid pattern background) -->
    <div class="relative w-full max-w-[1300px] mx-auto">
      <!-- Glow effect behind widget -->
      <div class="absolute -inset-4 bg-almond-cream/10 rounded-3xl blur-3xl pointer-events-none"></div>

      <!-- Split Layout Columns -->
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-stretch">
        
        <!-- Left Panel: Reporter (Chilean woman holding smartphone) -->
        <div class="relative rounded-2xl border border-dust-grey/80 overflow-hidden aspect-[16/10] md:aspect-[16/9.5] shadow-sm group bg-slate-50 flex flex-col justify-between">
          <!-- Background Photo -->
          <Image
            src={latinReporter}
            alt="Colaboradora enviando una denuncia anónima desde su smartphone con el canal ético de ConfiaLine"
            width={800}
            format="webp"
            quality={70}
            loading="eager"
            fetchpriority="high"
            class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.01]"
          />
          <!-- Dark gradient mask at bottom for text contrast -->
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/30 via-transparent to-transparent"></div>

          <!-- UI Overlays: Top Left (New Report Button) -->
          <div class="absolute top-4 left-4 sm:top-6 sm:left-6 z-10">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 sm:px-4 sm:py-2 rounded-full bg-[#00b594] text-white text-xs sm:text-sm font-semibold shadow-md">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              <span>Nuevo reporte</span>
            </div>
          </div>

          <!-- UI Overlays: Bottom Left (Anonymous Reporter Label) -->
          <div class="absolute bottom-4 left-4 sm:bottom-6 sm:left-6 z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#fa8a75] text-white text-xs font-semibold shadow-md">
              <span class="h-2 w-2 rounded-full bg-white animate-pulse"></span>
              <span>100% Anónimo y Seguro</span>
            </div>
          </div>

          <!-- Floating badge at border -->
          <div class="absolute -right-4 top-1/2 -translate-y-1/2 hidden lg:flex h-9 w-9 rounded-full bg-slate-900 border-2 border-white items-center justify-center text-white shadow-md z-20">
            <svg class="h-4.5 w-4.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
            </svg>
          </div>
        </div>

        <!-- Right Panel: Compliance Officer (Obscured over-the-shoulder laptop view) -->
        <div class="relative rounded-2xl border border-dust-grey/80 overflow-hidden aspect-[16/10] md:aspect-[16/9.5] shadow-sm group bg-slate-50">
          <!-- Background Photo -->
          <Image
            src={complianceOfficer}
            alt="Gestor de compliance revisando el estado de un caso en el panel de ConfiaLine"
            width={800}
            format="webp"
            quality={70}
            loading="eager"
            class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.01]"
          />
          <!-- Soft mask overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/15 via-transparent to-transparent"></div>

          <!-- UI Overlays: Floating Chat Bubble 1 (Informante question) -->
          <div class="absolute top-4 right-4 sm:top-6 sm:right-6 max-w-[70%] sm:max-w-[60%] z-10">
            <div class="bg-white/95 backdrop-blur-sm border border-slate-200 rounded-2xl rounded-tr-none p-3 shadow-md text-xs">
              <span class="block text-slate-400 font-mono text-[8px] uppercase tracking-wider mb-0.5">Usuario Anónimo</span>
              <p class="text-slate-800 font-medium leading-relaxed">¿Podrían investigar este caso a la brevedad? @Gestor</p>
            </div>
          </div>

          <!-- Status tracker card showing "En investigación" marked -->
          <div class="absolute bottom-4 right-4 sm:bottom-6 sm:right-6 w-36 sm:w-44 z-10">
            <div class="bg-white border border-slate-200 rounded-xl p-2.5 shadow-md font-mono text-[9px] sm:text-xs">
              <div class="pb-1.5 border-b border-slate-100 flex items-center justify-between text-[8px] uppercase tracking-wider text-slate-400 font-bold mb-1.5">
                <span>Estado Caso</span>
                <span class="h-2 w-2 rounded-full bg-[#00b594]"></span>
              </div>
              <ul class="space-y-1.5 text-slate-500 font-sans">
                <li class="flex items-center gap-1.5 text-slate-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-200"></span>
                  <span>Nuevo</span>
                </li>
                <li class="flex items-center gap-1.5 text-slate-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-200"></span>
                  <span>Triaje</span>
                </li>
                <li class="flex items-center gap-1.5 text-[#00b594] font-bold px-1.5 py-0.5 rounded bg-emerald-50 border border-emerald-100/50">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#00b594]"></span>
                  <span>En investigación</span>
                </li>
                <li class="flex items-center gap-1.5 text-slate-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-200"></span>
                  <span>Concluido</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- UI Overlays: Bottom Left (Compliance Officer Label) -->
          <div class="absolute bottom-4 left-4 sm:bottom-6 sm:left-6 z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#fa8a75] text-white text-xs font-semibold shadow-md">
              <span class="h-2 w-2 rounded-full bg-white animate-pulse"></span>
              <span>Gestor de Compliance</span>
            </div>
          </div>
        </div>

        <!-- Overlapping Report Details Card (shrunk to lg:w-[19rem], simplified content, and using new palette) -->
        <div class="lg:absolute lg:top-1/2 lg:left-1/2 lg:-translate-x-1/2 lg:-translate-y-1/2 w-full lg:w-[19rem] px-4 lg:px-0 mt-6 lg:mt-0 z-30">
          <div class="bg-white/95 backdrop-blur-md border border-dust-grey rounded-xl p-3 shadow-xl font-sans space-y-2.5">
            <div class="flex justify-between items-center pb-1.5 border-b border-dust-grey/35 text-[9px] sm:text-xs font-mono">
              <div class="flex items-center gap-1 text-slate-800 font-bold">
                <svg class="h-3.5 w-3.5 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <span>Reporte #CFL-173</span>
              </div>
              <span class="text-slate-400">19 Jun 2026</span>
            </div>
            
            <div class="space-y-0.5">
              <span class="text-[8px] uppercase tracking-wider text-slate-500 font-bold font-mono">Categoría</span>
              <p class="text-xs font-bold text-slate-900">Robo / Hurto de Activos</p>
            </div>
            
            <div class="space-y-0.5">
              <span class="text-[8px] uppercase tracking-wider text-slate-500 font-bold font-mono">Descripción</span>
              <p class="text-[11px] text-slate-700 leading-normal">
                Se están llevando cajas con mercadería de la bodega de Quilicura.
              </p>
            </div>
            
            <div class="pt-1.5 flex justify-between items-center text-[9px] font-mono text-emerald-800 font-bold bg-almond-cream/20 px-2 py-1 rounded border border-dust-grey/40">
              <span class="flex items-center gap-1">
                <svg class="h-3.5 w-3.5 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Canal 100% Cifrado
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
