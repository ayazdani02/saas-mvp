---
import { Image } from 'astro:assets';
import heroLeftApp from '../assets/hero_left_app.png';
import heroRightDashboard from '../assets/hero_right_dashboard.png';
---
<section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-32 overflow-hidden bg-white">
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Top Hero Info -->
    <div class="text-center max-w-6xl mx-auto mb-16 sm:mb-20">

      <!-- Short Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 leading-[1.15] text-balance mb-6">
        El canal de denuncias confiable y 100% privado.
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg lg:text-xl text-slate-700 max-w-5xl mx-auto mb-8 sm:mb-10 text-pretty leading-relaxed">
        Activamos tu canal anónimo e independiente en 24 horas. Una solución integral que une inteligencia artificial y especialistas dedicados para mitigar riesgos y transformar tu cumplimiento en una ventaja competitiva.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#demo" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-900 bg-almond-cream hover:bg-almond-cream-hover rounded-md shadow-sm hover:shadow-md text-center transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream">
          Agendar una Demo
        </a>
        <a href="#seguridad" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-850 hover:text-slate-950 bg-white hover:bg-floral-white border border-dust-grey hover:border-slate-400 rounded-md text-center transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream">
          Cómo protegemos la identidad
        </a>
      </div>
    </div>

    <!-- Responsive Layout container -->
    <div class="relative w-full max-w-[1300px] mx-auto">
      
      <!-- Glow effect behind widget -->
      <div class="absolute -inset-4 bg-almond-cream/5 rounded-[40px] blur-3xl pointer-events-none"></div>

      <!-- Split Layout Columns -->
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        
        <!-- Left Panel: Anonymous Smartphone App Mockup (No outer bounding box) -->
        <div class="relative flex justify-center lg:justify-end items-center reveal reveal-delay-200">
          <div class="relative w-full max-w-[340px] sm:max-w-[380px]">
            <Image
              src={heroLeftApp}
              alt="Interfaz móvil del informante anónimo ConfiaLine"
              width={380}
              format="png"
              quality={95}
              loading="eager"
              fetchpriority="high"
              class="w-full h-auto drop-shadow-[0_12px_28px_rgba(0,0,0,0.06)]"
            />
            
            <!-- HTML Badge: 100% Anónimo y Seguro (Floating over image) -->
            <div class="absolute top-6 left-6 z-10">
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#fa8a75] text-white text-xs font-semibold shadow-md">
                <span class="h-2 w-2 rounded-full bg-white animate-pulse"></span>
                <span>100% Anónimo y Seguro</span>
              </div>
            </div>

            <!-- HTML Bubble: Nuevo reporte enviado (Left floating card) -->
            <div class="absolute -left-12 bottom-12 w-64 bg-white/95 backdrop-blur-sm border border-dust-grey/85 rounded-xl p-3 shadow-lg font-sans">
              <div class="flex items-center gap-2.5">
                <div class="h-8 w-8 rounded-full bg-[#00b594] text-white flex items-center justify-center flex-shrink-0 font-bold shadow-sm">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                </div>
                <div>
                  <span class="block text-slate-900 font-bold text-xs leading-tight">Nuevo reporte enviado</span>
                  <span class="block text-slate-500 text-[9px] mt-0.5 font-medium leading-normal">Formulario completado y cifrado correctamente.</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating connector lines to center/right -->
          <div class="absolute right-[-40px] top-1/2 -translate-y-1/2 hidden lg:flex h-9 w-9 rounded-full bg-slate-900 border-2 border-white items-center justify-center text-white shadow-md z-20">
            <svg class="h-4.5 w-4.5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </div>
        </div>

        <!-- Right Panel: Laptop Dashboard Mockup (No outer bounding box) -->
        <div class="relative flex justify-center lg:justify-start items-center reveal reveal-delay-300">
          <div class="relative w-full max-w-[540px] lg:max-w-none">
            <Image
              src={heroRightDashboard}
              alt="Panel de control e interfaz de gestión de compliance de ConfiaLine"
              width={640}
              format="png"
              quality={95}
              loading="eager"
              class="w-full h-auto drop-shadow-[0_15px_35px_rgba(0,0,0,0.08)] rounded-xl"
            />

            <!-- HTML Bubble: Nuevo reporte recibido (Right floating card) -->
            <div class="absolute -left-8 top-12 w-64 bg-white/95 backdrop-blur-sm border border-dust-grey/85 rounded-xl p-3 shadow-lg font-sans z-10">
              <div class="flex items-center gap-2.5">
                <div class="h-8 w-8 rounded-full bg-[#00b594] text-white flex items-center justify-center flex-shrink-0 shadow-sm">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                  </svg>
                </div>
                <div>
                  <span class="block text-slate-900 font-bold text-xs leading-tight">Nuevo reporte recibido</span>
                  <span class="block text-slate-500 text-[9px] mt-0.5 font-medium leading-normal">Asunto: Conflicto de Interés<br/>Origen: Canal Ético (Anónimo)</span>
                </div>
              </div>
            </div>

            <!-- HTML Card: Status Tracker (Right floating tracker) -->
            <div class="absolute -right-6 bottom-12 w-40 bg-white border border-slate-200 rounded-xl p-2.5 shadow-md font-mono text-[10px] hidden sm:block z-10">
              <div class="pb-1.5 border-b border-slate-100 flex items-center justify-between text-[8px] uppercase tracking-wider text-slate-400 font-bold mb-1.5">
                <span>Estado Caso</span>
                <span class="h-1.5 w-1.5 rounded-full bg-[#00b594]"></span>
              </div>
              <ul class="space-y-1.5 text-slate-500 font-sans">
                <li class="flex items-center gap-1.5 text-slate-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-200"></span>
                  <span>Nuevo</span>
                </li>
                <li class="flex items-center gap-1.5 text-[#00b594] font-bold px-1.5 py-0.5 rounded bg-emerald-50 border border-emerald-100/50">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#00b594]"></span>
                  <span>En investigación</span>
                </li>
                <li class="flex items-center gap-1.5 text-slate-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-slate-200"></span>
                  <span>Concluido</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
