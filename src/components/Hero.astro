---
import { Image } from 'astro:assets';
import heroLeftAvatar from '../assets/hero_left_avatar.png';
import heroCenterDashboard from '../assets/hero_center_dashboard.png';
import heroRightDesk from '../assets/hero_right_desk.png';
---
<section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-32 overflow-hidden bg-white">
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Top Hero Info -->
    <div class="text-center max-w-6xl mx-auto mb-16 sm:mb-20">

      <!-- Short Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 leading-[1.15] text-balance mb-6">
        El canal de denuncias confiable y 100% privado.
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg lg:text-xl text-slate-700 max-w-5xl mx-auto mb-8 sm:mb-10 text-pretty leading-relaxed">
        Activamos tu canal anónimo e independiente en 24 horas. Una solución integral que une inteligencia artificial y especialistas dedicados para mitigar riesgos y transformar tu cumplimiento en una ventaja competitiva.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#demo" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-900 bg-almond-cream hover:bg-almond-cream-hover rounded-md shadow-sm hover:shadow-md text-center transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream">
          Agendar una Demo
        </a>
        <a href="#seguridad" class="w-full sm:w-auto px-8 py-3.5 text-base font-semibold text-slate-850 hover:text-slate-950 bg-white hover:bg-floral-white border border-dust-grey hover:border-slate-400 rounded-md text-center transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream">
          Cómo protegemos la identidad
        </a>
      </div>
    </div>

    <!-- Responsive Layout container -->
    <div class="relative w-full max-w-[1300px] mx-auto mt-12 lg:mt-16">
      
      <!-- Desktop layout: Overlapping components without enclosing boxes -->
      <div class="relative min-h-[560px] w-full hidden lg:block select-none">
        
        <!-- Background decorative ambient glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -inset-10 bg-almond-cream/5 rounded-[40px] blur-3xl pointer-events-none"></div>

        <!-- 1. Left visual: Reporter Avatar and Concentric lines -->
        <div class="absolute left-[-2%] top-[10px] w-[21%] z-20 reveal reveal-delay-300">
          <Image
            src={heroLeftAvatar}
            alt="Colaboradora enviando reporte"
            width={280}
            format="png"
            quality={95}
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto"
          />
        </div>

        <!-- HTML Bubble 1: "Nuevo reporte enviado" (Left side, absolute positioned) -->
        <div class="absolute left-[3.3%] top-[260px] w-[20%] z-30 bg-white border border-dust-grey/80 rounded-2xl p-4 shadow-lg text-left font-sans reveal reveal-delay-400">
          <div class="flex items-center gap-3">
            <div class="h-9 w-9 rounded-full bg-[#00b594] text-white flex items-center justify-center flex-shrink-0 font-bold shadow-sm">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </div>
            <div>
              <span class="block text-slate-900 font-bold text-xs sm:text-[13px] leading-tight">Nuevo reporte enviado</span>
              <span class="block text-slate-500 text-[10px] mt-0.5 font-medium">Se ha creado un nuevo reporte de forma 100% anónima.</span>
            </div>
          </div>
          <div class="mt-3 w-full bg-slate-100 h-1 rounded-full overflow-hidden">
            <div class="h-full bg-[#00b594] w-1/2 rounded-full"></div>
          </div>
        </div>

        <!-- SVG Green Arrow 1: Connecting Left Bubble to Dashboard -->
        <svg class="absolute left-[18%] top-[330px] w-[18%] h-[120px] z-10 pointer-events-none select-none text-emerald-600/70" viewBox="0 0 180 120" fill="none">
          <path d="M 10 30 C 50 80, 120 80, 170 30" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" fill="none" />
          <polygon points="170,30 163,36 166,28" fill="currentColor" />
        </svg>

        <!-- 2. Center visual: Dashboard mockup panel (no outer borders) -->
        <div class="absolute left-[20%] top-[40px] w-[53%] z-10 reveal-scale reveal-delay-200">
          <Image
            src={heroCenterDashboard}
            alt="Panel de control de ConfiaLine"
            width={700}
            format="png"
            quality={95}
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto drop-shadow-[0_12px_28px_rgba(0,0,0,0.06)]"
          />
        </div>

        <!-- HTML Bubble 2: "Nuevo reporte recibido" (Right side, absolute positioned) -->
        <div class="absolute right-[13.8%] top-[106px] w-[19%] z-30 bg-white border border-dust-grey/80 rounded-2xl p-4 shadow-lg text-left font-sans reveal reveal-delay-300">
          <div class="flex items-center gap-3">
            <div class="h-9 w-9 rounded-full bg-[#00b594] text-white flex items-center justify-center flex-shrink-0 font-bold shadow-sm">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </div>
            <div>
              <span class="block text-slate-900 font-bold text-xs sm:text-[13px] leading-tight">Nuevo reporte recibido</span>
              <span class="block text-slate-500 text-[10px] mt-0.5 font-medium font-sans">Asunto: Robo / Hurto de Activos<br/>Origen: ConfiaLine (Anónimo)</span>
            </div>
          </div>
          <div class="mt-3 w-full bg-slate-100 h-1 rounded-full overflow-hidden">
            <div class="h-full bg-[#00b594] w-2/3 rounded-full"></div>
          </div>
        </div>

        <!-- SVG Green Arrow 2: Connecting Dashboard to Compliance Officer -->
        <svg class="absolute right-[21%] top-[250px] w-[15%] h-[100px] z-10 pointer-events-none select-none text-emerald-600/70" viewBox="0 0 150 100" fill="none">
          <path d="M 10 10 C 50 30, 100 60, 140 80" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" fill="none" />
          <polygon points="140,80 133,74 139,72" fill="currentColor" />
        </svg>

        <!-- 3. Right visual: Compliance officer desk -->
        <div class="absolute right-[-1%] bottom-[10px] w-[30%] z-20 reveal reveal-delay-400">
          <Image
            src={heroRightDesk}
            alt="Gestión de compliance e investigación"
            width={390}
            format="png"
            quality={95}
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto"
          />
        </div>
      </div>

      <!-- Mobile/Tablet layout: Stacked clean grid representation -->
      <div class="block lg:hidden space-y-6 px-4">
        <!-- Dashboard mockup card -->
        <div class="w-full bg-white rounded-2xl border border-dust-grey/60 p-1 shadow-sm reveal reveal-delay-100">
          <Image
            src={heroCenterDashboard}
            alt="Panel de control de ConfiaLine"
            width={600}
            format="png"
            quality={90}
            loading="eager"
            class="w-full h-auto rounded-xl"
          />
        </div>

        <!-- Alerts Stacked on Mobile -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-white border border-dust-grey/70 rounded-2xl p-4 shadow-sm reveal reveal-delay-200">
            <div class="flex items-center gap-3">
              <div class="h-9 w-9 rounded-full bg-[#00b594] text-white flex items-center justify-center flex-shrink-0 font-bold">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </div>
              <div>
                <span class="block text-slate-900 font-bold text-xs">Nuevo reporte enviado</span>
                <span class="block text-slate-500 text-[10px] mt-0.5">Se ha creado un nuevo reporte de forma 100% anónima.</span>
              </div>
            </div>
          </div>

          <div class="bg-white border border-dust-grey/70 rounded-2xl p-4 shadow-sm reveal reveal-delay-300">
            <div class="flex items-center gap-3">
              <div class="h-9 w-9 rounded-full bg-[#00b594] text-white flex items-center justify-center flex-shrink-0 font-bold">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
              </div>
              <div>
                <span class="block text-slate-900 font-bold text-xs">Nuevo reporte recibido</span>
                <span class="block text-slate-500 text-[10px] mt-0.5">Asunto: Robo / Hurto de Activos (Anónimo)</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Avatars Stacked at Bottom on Mobile -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-slate-50/50 rounded-2xl border border-dust-grey/50 p-2 flex items-center justify-center reveal reveal-delay-200">
            <Image
              src={heroLeftAvatar}
              alt="Avatar informante"
              width={200}
              format="png"
              quality={90}
              class="w-full h-auto max-w-[140px] sm:max-w-[180px]"
            />
          </div>
          <div class="bg-slate-50/50 rounded-2xl border border-dust-grey/50 p-2 flex items-center justify-center reveal reveal-delay-300">
            <Image
              src={heroRightDesk}
              alt="Avatar gestor de compliance"
              width={200}
              format="png"
              quality={90}
              class="w-full h-auto max-w-[140px] sm:max-w-[180px]"
            />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
