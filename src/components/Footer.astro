---
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';
---
<footer class="bg-white border-t border-dust-grey/40 py-12 sm:py-16 relative">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12 sm:mb-16">
      
      <!-- Brand column -->
      <div class="space-y-4 md:col-span-2">
        <div class="flex items-center">
          <a href="/" aria-label="ConfiaLine — inicio" class="flex items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-almond-cream rounded-md">
            <Image src={logoImage} alt="ConfiaLine Logo" class="h-7 w-auto mix-blend-multiply" />
          </a>
        </div>
        <p class="text-sm text-slate-700 max-w-sm leading-relaxed font-sans">
          Plataforma independiente y segura de denuncias corporativas. Facilitamos el cumplimiento legal y la transparencia de las organizaciones mediante tecnología ética y humana.
        </p>
        <div class="pt-2 text-xs text-slate-500 flex items-center gap-2 font-mono">
          <span class="h-2 w-2 rounded-full bg-almond-cream"></span>
          <span>Alojamiento soberano en la nube de alta disponibilidad</span>
        </div>
      </div>

      <!-- Links Column 1: Producto -->
      <div>
        <h4 class="text-xs font-semibold text-slate-800 uppercase tracking-wider mb-4 font-mono">Producto</h4>
        <ul class="space-y-2.5 text-sm text-slate-650 font-sans">
          <li><a href="#producto" class="hover:text-slate-950 transition">Cómo funciona</a></li>
          <li><a href="#expertos" class="hover:text-slate-950 transition">Soporte Experto</a></li>
          <li><a href="#formularios" class="hover:text-slate-950 transition">Formularios</a></li>
          <li><a href="#seguridad" class="hover:text-slate-950 transition">Seguridad</a></li>
          <li><a href="#precios" class="hover:text-slate-950 transition">Planes</a></li>
        </ul>
      </div>

      <!-- Links Column 2: Legal -->
      <div>
        <h4 class="text-xs font-semibold text-slate-800 uppercase tracking-wider mb-4 font-mono">Legal y Seguridad</h4>
        <ul class="space-y-2.5 text-sm text-slate-655 font-sans">
          <li><a href="#seguridad" class="hover:text-slate-950 transition">Canal Seguro</a></li>
          <li><a href="#faq" class="hover:text-slate-950 transition">Preguntas Frecuentes</a></li>
          <li><a href="/privacidad" class="hover:text-slate-950 transition">Política de Privacidad</a></li>
          <li><a href="/terminos" class="hover:text-slate-950 transition">Términos de Servicio</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom footer -->
    <div class="pt-8 border-t border-dust-grey/35 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500 font-mono">
      <div>
        &copy; {new Date().getFullYear()} ConfiaLine Compliance Tech. Todos los derechos reservados.
      </div>
      <div class="flex items-center gap-4">
        <span class="px-2 py-0.5 rounded bg-floral-white border border-dust-grey/60 text-[10px] text-slate-700">ISO 27001 Ready</span>
        <span class="px-2 py-0.5 rounded bg-floral-white border border-dust-grey/60 text-[10px] text-slate-700">Compliance LATAM</span>
      </div>
    </div>
  </div>
</footer>
