---
---
<section id="producto" class="py-20 sm:py-28 bg-white border-t border-dust-grey/40 relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20 reveal">
      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-3 font-mono">Todo en un solo lugar</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight text-balance mb-4 font-sans">
        Control centralizado y trazabilidad completa de tus reportes éticos
      </h2>
      <p class="text-base text-slate-700 text-pretty">
        Monitorea, analiza y resuelve incidencias internamente de forma colaborativa, o derívalas a nuestro equipo de especialistas externos cuando lo requieras, a través de un panel de control avanzado que combina inteligencia de datos y privacidad absoluta.
      </p>
    </div>

    <!-- Full-Width Dashboard Mockup (placed first) -->
    <div class="max-w-[1280px] mx-auto bg-white border border-dust-grey rounded-2xl shadow-xl overflow-hidden font-sans reveal reveal-delay-200 mb-20 sm:mb-24">
      <!-- Windows Title Bar -->
      <div class="bg-floral-white/80 border-b border-dust-grey/60 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="h-3 w-3 rounded-full bg-red-400"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
          <div class="h-3 w-3 rounded-full bg-green-400"></div>
          <span class="ml-4 text-xs font-mono text-slate-500 font-semibold tracking-wider">PANEL DE CONTROL — CONFIALINE</span>
        </div>
        <div class="flex items-center gap-4 text-xs font-mono text-slate-500">
          <span class="px-2.5 py-1 rounded-md bg-white border border-dust-grey/50">ID Empresa: #CFL-LATAM</span>
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          <span class="font-bold text-slate-700">En línea</span>
        </div>
      </div>

      <!-- App Main Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[500px]">
        <!-- Sidebar -->
        <div class="lg:col-span-2 bg-floral-white/40 border-r border-dust-grey/50 p-4 space-y-6">
          <div class="space-y-1">
            <span class="px-2 text-[10px] uppercase font-mono tracking-wider text-slate-400 font-bold">Navegación</span>
            <ul class="space-y-1">
              <li>
                <a href="#producto" class="flex items-center gap-2.5 px-2.5 py-2 rounded-md bg-almond-cream/50 text-slate-900 font-semibold text-xs transition">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                  </svg>
                  Resumen
                </a>
              </li>
              <li>
                <span class="flex items-center gap-2.5 px-2.5 py-2 rounded-md text-slate-650 text-xs hover:bg-floral-white/80 cursor-not-allowed">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0V9a2 2 0 00-2-2H6a2 2 0 00-2 2v4h16z" />
                  </svg>
                  Casos Recibidos
                </span>
              </li>
              <li>
                <span class="flex items-center gap-2.5 px-2.5 py-2 rounded-md text-slate-650 text-xs hover:bg-floral-white/80 cursor-not-allowed">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 00-2 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                  Estadísticas
                </span>
              </li>
            </ul>
          </div>

          <div class="space-y-1">
            <span class="px-2 text-[10px] uppercase font-mono tracking-wider text-slate-400 font-bold">Filtros</span>
            <ul class="space-y-1.5 text-xs text-slate-655 px-2.5">
              <li class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
                <span>Derivados (Expertos)</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                <span>Internos (Comité)</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-slate-300 flex-shrink-0"></span>
                <span>Resueltos</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Main Dashboard View -->
        <div class="lg:col-span-10 p-6 space-y-6">
          <!-- Stats Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Stat 1 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Total Reportes</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">14</span>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 px-1.5 py-0.5 rounded border border-emerald-100">+2 esta semana</span>
              </div>
            </div>
            <!-- Stat 2 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Derivados a Expertos</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">5</span>
                <span class="text-xs font-semibold text-emerald-750 bg-emerald-50 px-1.5 py-0.5 rounded border border-emerald-100">2 Activos, 3 Cerrados</span>
              </div>
            </div>
            <!-- Stat 3 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Gestión Interna</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">3</span>
                <span class="text-xs font-semibold text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded border border-amber-100">Comité Interno</span>
              </div>
            </div>
            <!-- Stat 4 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Tiempo Medio</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">6 días</span>
                <span class="text-xs font-semibold text-slate-500 bg-slate-50 px-1.5 py-0.5 rounded border border-slate-100">Meta: &lt;15 días</span>
              </div>
            </div>
          </div>

          <!-- Bottom Grid: Reports List + IA Panel -->
          <div class="grid grid-cols-1 xl:grid-cols-12 gap-6 items-start">
            <!-- Table of Reports (Left) -->
            <div class="xl:col-span-7 border border-dust-grey/65 rounded-xl overflow-hidden bg-white shadow-sm">
              <div class="px-4 py-3 bg-floral-white/60 border-b border-dust-grey/60 flex justify-between items-center">
                <span class="text-xs font-bold text-slate-800 font-mono">Bandeja de Entrada de Casos</span>
                <span class="text-[10px] text-slate-500">Última actualización: hace un momento</span>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-xs">
                  <thead>
                    <tr class="border-b border-dust-grey/40 bg-floral-white/20 text-slate-500 font-mono text-[10px] uppercase font-bold">
                      <th class="p-3">Código</th>
                      <th class="p-3">Categoría</th>
                      <th class="p-3">Fecha</th>
                      <th class="p-3">Asignación</th>
                      <th class="p-3">Estado</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-dust-grey/30">
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-173</td>
                      <td class="p-3 font-semibold text-slate-800">Conflicto de Interés</td>
                      <td class="p-3 text-slate-550">Ayer</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-800 border border-emerald-200/60 font-semibold font-mono text-[10px]">Equipo Experto</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-amber-50 text-amber-700 border border-amber-100">Análisis Legal</span>
                      </td>
                    </tr>
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-172</td>
                      <td class="p-3 font-semibold text-slate-800">Acoso Laboral (Ley Karin)</td>
                      <td class="p-3 text-slate-550">18 Jun 2026</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-slate-50 text-slate-600 border border-slate-200/60 font-medium font-mono text-[10px]">Comité Interno</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-blue-50 text-blue-700 border border-blue-100">Triage Inicial</span>
                      </td>
                    </tr>
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-171</td>
                      <td class="p-3 font-semibold text-slate-800">Fraude Financiero</td>
                      <td class="p-3 text-slate-550">16 Jun 2026</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-800 border border-emerald-200/60 font-semibold font-mono text-[10px]">Equipo Experto</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">Dictamen Emitido</span>
                      </td>
                    </tr>
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-170</td>
                      <td class="p-3 font-semibold text-slate-800">Uso Indebido de Activos</td>
                      <td class="p-3 text-slate-550">14 Jun 2026</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-slate-50 text-slate-600 border border-slate-200/60 font-medium font-mono text-[10px]">Comité Interno</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-slate-50 text-slate-500 border border-slate-200">Resuelto</span>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- AI Insights Panel (Right) -->
            <div class="xl:col-span-5 border border-dust-grey/65 rounded-xl bg-floral-white/30 p-5 space-y-4">
              <div class="flex items-center justify-between pb-3 border-b border-dust-grey/50">
                <div class="flex items-center gap-2">
                  <div class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></div>
                  <span class="text-xs font-bold text-slate-850 font-mono">IA RESUMEN E INSIGHTS</span>
                </div>
                <span class="text-[9px] font-mono bg-almond-cream/40 px-2 py-0.5 rounded text-slate-800 border border-dust-grey/50">Caso Activo #CFL-173</span>
              </div>

              <!-- Referral Banner Indicator -->
              <div class="p-2.5 bg-emerald-50 border border-emerald-200/60 rounded-lg flex items-center justify-between text-[11px] text-emerald-800">
                <div class="flex items-center gap-2 font-semibold">
                  <span class="h-2 w-2 rounded-full bg-emerald-600 animate-pulse"></span>
                  <span>Derivado al Equipo Experto Legal</span>
                </div>
                <span class="font-mono text-[9px] px-1.5 py-0.5 bg-emerald-100 rounded text-emerald-700 font-bold border border-emerald-250/40">En Análisis</span>
              </div>

              <div class="space-y-3">
                <div class="space-y-1">
                  <span class="text-[9px] font-mono text-slate-400 font-bold uppercase tracking-wider">Análisis Inteligente</span>
                  <p class="text-xs text-slate-800 leading-relaxed bg-white p-3 rounded-lg border border-dust-grey/30">
                    El reporte describe irregularidades en compras del área logística, sospechando favoritismo hacia el proveedor X. Nuestra IA detectó un **89% de coincidencia semántica** con un reporte archivado en 2025 (Caso #CFL-089).
                  </p>
                </div>

                <div class="space-y-1">
                  <span class="text-[9px] font-mono text-slate-400 font-bold uppercase tracking-wider">Pasos Recomendados</span>
                  <ul class="text-xs text-slate-750 space-y-1.5 list-disc pl-4 leading-normal font-sans">
                    <li>Solicitar facturas de compras asociadas al proveedor X.</li>
                    <li>Revisar pliego de condiciones de licitación logística de 2025.</li>
                    <li>Asignar caso a auditoría de finanzas.</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Advantages (Grid of 4 - placed second) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
      <!-- Card 1: AI-Enhanced -->
      <div class="bg-floral-white border border-dust-grey/65 rounded-xl p-6 flex flex-col justify-between hover:border-almond-cream-hover hover:shadow-sm transition duration-300 reveal reveal-delay-100">
        <div>
          <div class="h-9 w-9 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 mb-5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-2">AI-Enhanced</h3>
          <p class="text-xs text-slate-700 leading-relaxed">
            Clasificación automática de casos, resúmenes generados por inteligencia artificial y alertas de similitud preventivas.
          </p>
        </div>
      </div>

      <!-- Card 2: Fácil de utilizar -->
      <div class="bg-floral-white border border-dust-grey/65 rounded-xl p-6 flex flex-col justify-between hover:border-almond-cream-hover hover:shadow-sm transition duration-300 reveal reveal-delay-200">
        <div>
          <div class="h-9 w-9 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 mb-5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-2">Fácil de utilizar</h3>
          <p class="text-xs text-slate-700 leading-relaxed">
            Interfaz ágil e intuitiva que elimina la fricción para los colaboradores y optimiza las tareas de resolución interna.
          </p>
        </div>
      </div>

      <!-- Card 3: 100% Seguro -->
      <div class="bg-floral-white border border-dust-grey/65 rounded-xl p-6 flex flex-col justify-between hover:border-almond-cream-hover hover:shadow-sm transition duration-300 reveal reveal-delay-300">
        <div>
          <div class="h-9 w-9 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 mb-5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-2">100% Seguro</h3>
          <p class="text-xs text-slate-700 leading-relaxed">
            Cifrado inmutable AES-256-GCM y sanitización total de metadatos en documentos para resguardar la identidad.
          </p>
        </div>
      </div>

      <!-- Card 4: Muy customizable -->
      <div class="bg-floral-white border border-dust-grey/65 rounded-xl p-6 flex flex-col justify-between hover:border-almond-cream-hover hover:shadow-sm transition duration-300 reveal reveal-delay-400">
        <div>
          <div class="h-9 w-9 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 mb-5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-2">Muy customizable</h3>
          <p class="text-xs text-slate-700 leading-relaxed">
            Adapta los campos de registro, los flujos relacionales de auditoría y la marca gráfica a los requerimientos de tu organización.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
