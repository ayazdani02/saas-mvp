---
---
<section id="producto" class="py-20 sm:py-28 bg-white border-t border-dust-grey/40 relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20 reveal">
      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-3 font-mono">Todo en un solo lugar</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight text-balance mb-4 font-sans">
        Maneja tus casos de manera centralizada y con total trazabilidad
      </h2>
      <p class="text-base text-slate-700 text-pretty">
        Monitorea, analiza y resuelve incidencias internamente de forma colaborativa, o derívalas a nuestro equipo de especialistas externos cuando lo requieras, a través de un panel de control avanzado que combina inteligencia de datos y privacidad absoluta.
      </p>
    </div>

    <!-- Full-Width Dashboard Mockup (placed first) -->
    <div class="max-w-[1280px] mx-auto bg-white border border-dust-grey rounded-2xl shadow-xl overflow-hidden font-sans reveal reveal-delay-200 mb-20 sm:mb-24">
      <!-- Windows Title Bar -->
      <div class="bg-floral-white/80 border-b border-dust-grey/60 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="h-3 w-3 rounded-full bg-red-400"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
          <div class="h-3 w-3 rounded-full bg-green-400"></div>
          <span class="ml-4 text-xs font-mono text-slate-500 font-semibold tracking-wider">PANEL DE CONTROL — CONFIALINE</span>
        </div>
        <div class="flex items-center gap-4 text-xs font-mono text-slate-500">
          <span class="px-2.5 py-1 rounded-md bg-white border border-dust-grey/50">ID Empresa: #CFL-LATAM</span>
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          <span class="font-bold text-slate-700">En línea</span>
        </div>
      </div>

      <!-- App Main Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[500px]">
        <!-- Sidebar -->
        <div class="lg:col-span-2 bg-floral-white/40 border-r border-dust-grey/50 p-4 flex flex-col justify-between min-h-[580px]">
          <div class="space-y-6">
            <!-- Navegación -->
            <div class="space-y-1">
              <span class="px-2 text-[10px] uppercase font-mono tracking-wider text-slate-400 font-bold">Navegación</span>
              <ul class="space-y-1">
                <li>
                  <a href="#producto" class="flex items-center gap-2.5 px-2.5 py-2 rounded-md bg-almond-cream/50 text-slate-900 font-semibold text-xs transition">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    Resumen
                  </a>
                </li>
                <li>
                  <span class="flex items-center gap-2.5 px-2.5 py-2 rounded-md text-slate-655 text-xs hover:bg-floral-white/80 cursor-not-allowed">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0V9a2 2 0 00-2-2H6a2 2 0 00-2 2v4h16z" />
                    </svg>
                    Casos Recibidos
                  </span>
                </li>
                <li>
                  <span class="flex items-center gap-2.5 px-2.5 py-2 rounded-md text-slate-655 text-xs hover:bg-floral-white/80 cursor-not-allowed">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 00-2 2h2a2 2 0 002-2m0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    Estadísticas
                  </span>
                </li>
              </ul>
            </div>

            <!-- Filtros -->
            <div class="space-y-1">
              <span class="px-2 text-[10px] uppercase font-mono tracking-wider text-slate-400 font-bold">Filtros</span>
              <ul class="space-y-1.5 text-xs text-slate-655 px-2.5">
                <li class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
                  <span>Derivados (ConfiaLine)</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                  <span>Interna</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-slate-300 flex-shrink-0"></span>
                  <span>Resueltos</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Configuración y Cerrar Sesión -->
          <div class="space-y-4 pt-4 border-t border-dust-grey/30">
            <div class="space-y-1">
              <span class="px-2 text-[10px] uppercase font-mono tracking-wider text-slate-400 font-bold">Configuración</span>
              <ul class="space-y-0.5">
                <li>
                  <a href="#formularios" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md text-slate-655 hover:text-slate-900 hover:bg-floral-white/85 text-xs transition">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Formularios
                  </a>
                </li>
                <li>
                  <span class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md text-slate-655 hover:text-slate-900 hover:bg-floral-white/85 text-xs transition cursor-pointer">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v12m0 0l4-4m-4 4l-4-4m12-8V7a2 2 0 00-2-2H8" />
                    </svg>
                    Workflows
                  </span>
                </li>
                <li>
                  <span class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md text-slate-655 hover:text-slate-900 hover:bg-floral-white/85 text-xs transition cursor-pointer">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    Automatizaciones
                  </span>
                </li>
                <li>
                  <span class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md text-slate-650 text-xs hover:bg-floral-white/85 cursor-not-allowed">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    Control de acceso
                  </span>
                </li>
              </ul>
            </div>

            <div class="pt-1">
              <a href="/" class="flex items-center gap-2.5 px-2.5 py-1.5 rounded-md text-red-655 hover:text-red-805 hover:bg-red-50/50 text-xs font-semibold transition">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Cerrar sesión
              </a>
            </div>
          </div>
        </div>

        <!-- Main Dashboard View -->
        <div class="lg:col-span-10 p-6 space-y-6">
          <!-- App Header -->
          <div class="flex justify-between items-center pb-4 border-b border-dust-grey/40">
            <div>
              <h3 class="text-lg font-bold text-slate-900 font-sans">Panel de Control</h3>
              <p class="text-xs text-slate-500">Resumen y estado de las denuncias recibidas</p>
            </div>
            <!-- User Profile (Sergio Rubilar) -->
            <div class="flex items-center gap-3 bg-floral-white/50 px-3.5 py-1.5 rounded-lg border border-dust-grey/30">
              <div class="text-right hidden sm:block font-sans">
                <span class="block text-xs font-bold text-slate-800">Sergio Rubilar</span>
                <span class="block text-[10px] text-slate-500 font-mono">Gestor de Compliance</span>
              </div>
              <div class="h-8 w-8 rounded-full bg-slate-200 border border-dust-grey overflow-hidden flex items-center justify-center flex-shrink-0 shadow-sm relative">
                <!-- User Profile Photo icon representation -->
                <svg class="h-5 w-5 text-slate-550" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                </svg>
                <span class="absolute bottom-0 right-0 h-2.5 w-2.5 rounded-full bg-emerald-500 border-2 border-white"></span>
              </div>
            </div>
          </div>
          <!-- Stats Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Stat 1 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Total Reportes</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">14</span>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 px-1.5 py-0.5 rounded border border-emerald-100">+2 esta semana</span>
              </div>
            </div>
            <!-- Stat 2 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Derivados a Expertos</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">5</span>
                <span class="text-xs font-semibold text-emerald-750 bg-emerald-50 px-1.5 py-0.5 rounded border border-emerald-100">2 Activos, 3 Cerrados</span>
              </div>
            </div>
            <!-- Stat 3 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Gestión Interna</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">3</span>
                <span class="text-xs font-semibold text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded border border-amber-100">Interna</span>
              </div>
            </div>
            <!-- Stat 4 -->
            <div class="border border-dust-grey/60 rounded-xl p-4 bg-floral-white/20">
              <span class="block text-[10px] font-mono uppercase tracking-wider text-slate-400 font-bold mb-1">Tiempo Medio</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-slate-900">6 días</span>
                <span class="text-xs font-semibold text-slate-500 bg-slate-50 px-1.5 py-0.5 rounded border border-slate-100">Meta: &lt;15 días</span>
              </div>
            </div>
          </div>

          <!-- Bottom Grid: Reports List (Full Width) -->
          <div class="w-full">
            <!-- Table of Reports -->
            <div class="w-full border border-dust-grey/65 rounded-xl overflow-hidden bg-white shadow-sm">
              <!-- Filter Options Row -->
              <div class="px-4 py-3 bg-slate-50/50 border-b border-dust-grey/40 flex flex-wrap gap-2 items-center justify-between text-[11px]">
                <div class="flex items-center gap-1.5 overflow-x-auto">
                  <span class="text-slate-400 font-mono font-bold uppercase tracking-wider text-[9px] mr-1">Filtros:</span>
                  <button class="px-2.5 py-1 rounded bg-slate-200 text-slate-800 font-semibold transition">Todos</button>
                  <button class="px-2.5 py-1 rounded bg-white border border-dust-grey/50 hover:bg-slate-50 text-slate-655 transition">ConfiaLine (5)</button>
                  <button class="px-2.5 py-1 rounded bg-white border border-dust-grey/50 hover:bg-slate-50 text-slate-655 transition">Interna (3)</button>
                  <button class="px-2.5 py-1 rounded bg-white border border-dust-grey/50 hover:bg-slate-50 text-slate-655 transition">Prioridad Alta</button>
                </div>
                <div class="flex items-center gap-1 font-sans text-slate-500 text-[10px]">
                  <span>Ordenar:</span>
                  <span class="font-semibold text-slate-700 cursor-pointer hover:text-slate-955 flex items-center gap-0.5">
                    Recientes
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </span>
                </div>
              </div>

              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-xs">
                  <thead>
                    <tr class="border-b border-dust-grey/40 bg-floral-white/20 text-slate-500 font-mono text-[10px] uppercase font-bold">
                      <th class="p-3">Código</th>
                      <th class="p-3">Categoría</th>
                      <th class="p-3">Fecha</th>
                      <th class="p-3">Asignación</th>
                      <th class="p-3">Prioridad</th>
                      <th class="p-3">Estado</th>
                      <th class="p-3 text-right">Acciones</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-dust-grey/30">
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-173</td>
                      <td class="p-3 font-semibold text-slate-800">Conflicto de Interés</td>
                      <td class="p-3 text-slate-550">Ayer</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-800 border border-emerald-250/60 font-semibold font-mono text-[10px]">ConfiaLine</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-amber-50 text-amber-700 border border-amber-100">Media</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-amber-50 text-amber-700 border border-amber-100">Análisis Legal</span>
                      </td>
                      <td class="p-3 text-right">
                        <button class="p-1 hover:bg-slate-100 rounded text-slate-400 hover:text-slate-700 transition animate-none" aria-label="Acciones">
                          <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                          </svg>
                        </button>
                      </td>
                    </tr>
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-172</td>
                      <td class="p-3 font-semibold text-slate-800">Acoso Laboral (Ley Karin)</td>
                      <td class="p-3 text-slate-550">18 Jun 2026</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-slate-50 text-slate-655 border border-slate-200/60 font-medium font-mono text-[10px]">Interna</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-red-50 text-red-700 border border-red-100">Alta</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-blue-50 text-blue-700 border border-blue-100">Triage Inicial</span>
                      </td>
                      <td class="p-3 text-right">
                        <button class="p-1 hover:bg-slate-100 rounded text-slate-400 hover:text-slate-700 transition animate-none" aria-label="Acciones">
                          <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                          </svg>
                        </button>
                      </td>
                    </tr>
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-171</td>
                      <td class="p-3 font-semibold text-slate-800">Fraude Financiero</td>
                      <td class="p-3 text-slate-550">16 Jun 2026</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-800 border border-emerald-250/60 font-semibold font-mono text-[10px]">ConfiaLine</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-red-50 text-red-700 border border-red-100">Alta</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">Dictamen Emitido</span>
                      </td>
                      <td class="p-3 text-right">
                        <button class="p-1 hover:bg-slate-100 rounded text-slate-400 hover:text-slate-700 transition animate-none" aria-label="Acciones">
                          <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                          </svg>
                        </button>
                      </td>
                    </tr>
                    <tr class="hover:bg-floral-white/30 cursor-pointer transition">
                      <td class="p-3 font-mono font-bold text-slate-900">#CFL-170</td>
                      <td class="p-3 font-semibold text-slate-800">Uso Indebido de Activos</td>
                      <td class="p-3 text-slate-550">14 Jun 2026</td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded bg-slate-50 text-slate-655 border border-slate-200/60 font-medium font-mono text-[10px]">Interna</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-slate-50 text-slate-600 border border-slate-200/60 font-medium">Baja</span>
                      </td>
                      <td class="p-3">
                        <span class="px-2 py-0.5 rounded-full text-[9px] font-bold bg-amber-50 text-amber-700 border border-amber-100">En Investigación</span>
                      </td>
                      <td class="p-3 text-right">
                        <button class="p-1 hover:bg-slate-100 rounded text-slate-400 hover:text-slate-700 transition animate-none" aria-label="Acciones">
                          <svg class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                          </svg>
                        </button>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Advantages (Grid of 4 - placed second) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
      <!-- Card 1: Potenciado por IA -->
      <div class="bg-floral-white border border-dust-grey/65 rounded-xl p-6 flex flex-col justify-between hover:border-almond-cream-hover hover:shadow-sm transition duration-300 reveal reveal-delay-100">
        <div>
          <div class="h-9 w-9 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 mb-5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-2">Potenciado por IA</h3>
          <p class="text-xs text-slate-700 leading-relaxed">
            Automatiza la clasificación inicial de casos, genera resúmenes inteligentes de forma inmediata y detecta patrones o alertas de similitud preventivas.
          </p>
        </div>
      </div>

      <!-- Card 2: Fácil de utilizar -->
      <div class="bg-floral-white border border-dust-grey/65 rounded-xl p-6 flex flex-col justify-between hover:border-almond-cream-hover hover:shadow-sm transition duration-300 reveal reveal-delay-200">
        <div>
          <div class="h-9 w-9 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 mb-5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
