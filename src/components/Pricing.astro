---
---
<section id="precios" class="py-20 sm:py-28 bg-white border-t border-dry-sage/40 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-light-bronze mb-3 font-mono">Planes y Precios</h2>
      <p class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight text-balance mb-4">
        Soluciones flexibles y transparentes para tu organización
      </p>
      <p class="text-base sm:text-lg text-slate-700 text-pretty">
        Desde el cumplimiento normativo básico hasta la externalización del triaje y auditoría. Selecciona el plan adecuado para tu plantilla.
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto items-stretch">
      
      <!-- Tier 1: Lite -->
      <div class="bg-papaya-whip border border-dry-sage/60 rounded-2xl p-8 flex flex-col justify-between hover:border-light-bronze hover:shadow-sm transition duration-300">
        <div>
          <div class="mb-6">
            <h3 class="text-lg font-bold text-slate-900 mb-2 font-serif-title">Lite</h3>
            <p class="text-xs text-slate-600 leading-relaxed">Ideal para pequeñas empresas que buscan una solución de reporte directa.</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-bold text-slate-900">49€</span>
            <span class="text-sm text-slate-500 font-medium">/ mes</span>
          </div>
          
          <ul class="space-y-4 text-xs sm:text-sm text-slate-700 mb-8 border-t border-dry-sage/35 pt-6">
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Formulario web independiente</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Código QR listo para distribución</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Gestión interna básica (1 administrador)</span>
            </li>
            <li class="flex items-center gap-3 text-slate-500/60 line-through decoration-dry-sage/30">
              <svg class="h-4 w-4 text-dry-sage/70 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span>Triaje asistido por IA</span>
            </li>
            <li class="flex items-center gap-3 text-slate-500/60 line-through decoration-dry-sage/30">
              <svg class="h-4 w-4 text-dry-sage/70 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span>Chat de seguimiento anónimo</span>
            </li>
          </ul>
        </div>
        
        <a href="#contacto-lite" class="w-full py-3 px-4 text-center text-sm font-semibold text-slate-800 bg-beige/40 hover:bg-beige/80 border border-dry-sage/60 rounded-md transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-light-bronze">
          Empezar con Lite
        </a>
      </div>

      <!-- Tier 2: Pro (Recomendado) -->
      <div class="relative bg-white border-2 border-light-bronze rounded-2xl p-8 flex flex-col justify-between shadow-[0_4px_25px_rgba(212,163,115,0.08)] hover:shadow-[0_4px_30px_rgba(212,163,115,0.15)] transition duration-300">
        <!-- Highlight badge -->
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-3.5 py-1 rounded-full bg-light-bronze text-white text-xs font-bold uppercase tracking-wider">
          Recomendado
        </div>

        <div>
          <div class="mb-6">
            <h3 class="text-lg font-bold text-slate-900 mb-2 font-serif-title">Pro (Gestión Asistida)</h3>
            <p class="text-xs text-slate-650 leading-relaxed">Cumplimiento automatizado y herramientas de investigación seguras.</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-bold text-slate-900">149€</span>
            <span class="text-sm text-slate-500 font-medium">/ mes</span>
          </div>
          
          <ul class="space-y-4 text-xs sm:text-sm text-slate-750 mb-8 border-t border-dry-sage/40 pt-6">
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-medium text-slate-900">Todo lo de Lite</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-light-bronze">Sugerencias y resúmenes con IA</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Chat de seguimiento bidireccional</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Trazabilidad inmutable sellada digitalmente</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Alertas legales y gestores múltiples</span>
            </li>
          </ul>
        </div>
        
        <a href="#contacto-pro" class="w-full py-3.5 px-4 text-center text-sm font-bold text-white bg-light-bronze hover:bg-light-bronze-hover rounded-md shadow-sm transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-light-bronze">
          Probar Plan Pro
        </a>
      </div>

      <!-- Tier 3: Enterprise -->
      <div class="bg-papaya-whip border border-dry-sage/60 rounded-2xl p-8 flex flex-col justify-between hover:border-light-bronze hover:shadow-sm transition duration-300">
        <div>
          <div class="mb-6">
            <h3 class="text-lg font-bold text-slate-900 mb-2 font-serif-title">Enterprise</h3>
            <p class="text-xs text-slate-655 leading-relaxed">Canal operado por terceros para total independencia y blindaje.</p>
          </div>
          <div class="mb-6">
            <span class="text-4xl font-bold text-slate-900">Personalizado</span>
          </div>
          
          <ul class="space-y-4 text-xs sm:text-sm text-slate-700 mb-8 border-t border-dry-sage/35 pt-6">
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Todo lo de Pro</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-light-bronze">Operación externa (Abogados independientes)</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Informes consolidados para el Directorio</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>Integración con Directorios Activos y ERPs</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-4 w-4 text-light-bronze flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>SLA de respuesta garantizado por contrato</span>
            </li>
          </ul>
        </div>
        
        <a href="#contacto-enterprise" class="w-full py-3 px-4 text-center text-sm font-semibold text-slate-800 bg-beige/40 hover:bg-beige/80 border border-dry-sage/60 rounded-md transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-light-bronze">
          Contactar con Ventas
        </a>
      </div>

    </div>
  </div>
</section>
