---
---
<section id="formularios" class="py-20 sm:py-28 bg-floral-white/40 border-t border-b border-dust-grey/40 relative">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Copy Column (Left) -->
      <div class="lg:col-span-5 space-y-6 reveal">
        <h2 class="text-xs font-bold uppercase tracking-wider text-emerald-700 font-mono">Formularios a tu medida</h2>
        <h3 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight text-balance leading-tight">
          Crea la experiencia que da confianza a tu equipo
        </h3>
        <p class="text-base text-slate-700 text-pretty leading-relaxed">
          Diseña formularios de denuncia intuitivos en minutos. ConfiaLine se integra de manera inmediata en el sitio web o intranet de tu empresa, garantizando una interfaz empática y accesible para tus colaboradores y proveedores.
        </p>

        <!-- Core Advantages -->
        <div class="space-y-6 pt-4">
          <!-- Point 1 -->
          <div class="flex gap-4">
            <div class="h-6 w-6 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 flex-shrink-0">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-900">Personalización Drag & Drop</h4>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                Arrastra y suelta preguntas abiertas, selectores múltiples o módulos de carga de evidencia. Adapta los campos según las normativas y los departamentos de tu organización sin escribir código.
              </p>
            </div>
          </div>

          <!-- Point 2 -->
          <div class="flex gap-4">
            <div class="h-6 w-6 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 flex-shrink-0">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-900">Vínculo simple en tu sitio web corporativo</h4>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                Integra el canal ético en tu web (`tuempresa.com/canal-etico`) en un clic. Puedes embeber el formulario directamente en un iframe seguro o enlazarlo con un botón personalizado sin fricciones técnicas.
              </p>
            </div>
          </div>

          <!-- Point 3 -->
          <div class="flex gap-4">
            <div class="h-6 w-6 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-700 flex-shrink-0">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-900">UX enfocada en la confianza del colaborador</h4>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                La seguridad psicológica es clave. Diseñamos flujos limpios con preguntas sencillas guiadas paso a paso, selección rápida de anonimato y accesibilidad móvil completa para que denunciar sea seguro y libre de estrés.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Drag & Drop Mockup Column (Right) -->
      <div class="lg:col-span-7 relative reveal reveal-delay-200">
        
        <!-- Background decorative glows -->
        <div class="absolute -inset-4 bg-almond-cream/15 rounded-3xl blur-3xl pointer-events-none"></div>

        <!-- Address Bar Integration Representation -->
        <div class="w-full bg-white border border-dust-grey rounded-t-xl px-4 py-2.5 flex items-center justify-between gap-3 shadow-xs border-b-0">
          <div class="flex items-center gap-1.5">
            <span class="h-3 w-3 rounded-full bg-red-400/80"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400/80"></span>
            <span class="h-3 w-3 rounded-full bg-green-400/80"></span>
          </div>
          <div class="flex-grow max-w-md bg-floral-white/80 border border-dust-grey/70 rounded-md py-1 px-3 text-[11px] text-slate-500 text-center font-mono select-none truncate">
            https://www.tuempresa.com/canal-etico
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[9px] font-mono px-2 py-0.5 rounded bg-emerald-50 border border-emerald-100 text-emerald-800 font-semibold uppercase">Embebido</span>
          </div>
        </div>

        <!-- Main Workspace (Editor Interface) -->
        <div class="bg-white border border-dust-grey rounded-b-xl shadow-md p-4 sm:p-6 grid grid-cols-1 sm:grid-cols-12 gap-5 relative overflow-hidden">
          
          <!-- Left Panel: Form Blocks (4 cols) -->
          <div class="sm:col-span-5 bg-slate-50 border border-slate-100 rounded-xl p-3 space-y-3 select-none">
            <div class="pb-2 border-b border-slate-200">
              <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold font-mono">Bloques de Campo</span>
            </div>
            
            <div class="flex flex-col gap-2">
              <!-- Block 1 -->
              <div class="bg-white border border-dust-grey/60 rounded-lg p-2 flex items-center justify-between text-xs text-slate-700 cursor-grab hover:border-slate-400 transition">
                <div class="flex items-center gap-2">
                  <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                  <span>Texto Corto</span>
                </div>
                <span class="text-[9px] text-slate-400 font-mono">TXT</span>
              </div>

              <!-- Block 2 (Inactive state showing it was dragged) -->
              <div class="bg-white/50 border border-dashed border-dust-grey/40 rounded-lg p-2 flex items-center justify-between text-xs text-slate-400 transition">
                <div class="flex items-center gap-2">
                  <svg class="h-3.5 w-3.5 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                  </svg>
                  <span>Carga de Evidencia</span>
                </div>
                <span class="text-[9px] text-slate-300 font-mono">FILE</span>
              </div>

              <!-- Block 3 -->
              <div class="bg-white border border-dust-grey/60 rounded-lg p-2 flex items-center justify-between text-xs text-slate-700 cursor-grab hover:border-slate-400 transition">
                <div class="flex items-center gap-2">
                  <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>Fecha de Suceso</span>
                </div>
                <span class="text-[9px] text-slate-400 font-mono">DATE</span>
              </div>

              <!-- Block 4 -->
              <div class="bg-white border border-dust-grey/60 rounded-lg p-2 flex items-center justify-between text-xs text-slate-700 cursor-grab hover:border-slate-400 transition">
                <div class="flex items-center gap-2">
                  <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>Selector Anonimato</span>
                </div>
                <span class="text-[9px] text-slate-400 font-mono">CONF</span>
              </div>
            </div>
            
            <div class="pt-4 border-t border-slate-200">
              <div class="bg-almond-cream/20 border border-dust-grey/50 p-2.5 rounded-lg text-[10px] text-slate-600 leading-normal">
                💡 <strong>Consejo:</strong> Los cambios se sincronizan en vivo en tu sitio web corporativo sin recargar.
              </div>
            </div>
          </div>

          <!-- Right Panel: Active Canvas (7 cols) -->
          <div class="sm:col-span-7 bg-white border border-slate-100 rounded-xl p-4 flex flex-col justify-between min-h-[300px] relative shadow-2xs">
            <div class="space-y-4">
              <!-- Form Header inside canvas -->
              <div class="pb-2 border-b border-slate-100">
                <span class="text-[10px] font-bold text-slate-900 font-serif-title block">Vista Previa del Formulario</span>
                <span class="text-[8px] text-slate-400">Canal de Denuncias Éticas</span>
              </div>
              
              <!-- Form Fields -->
              <div class="space-y-3">
                <!-- Field 1: Category -->
                <div class="bg-floral-white/50 border border-dust-grey/40 p-2.5 rounded-lg">
                  <div class="flex justify-between items-center mb-1">
                    <label class="text-[10px] font-bold text-slate-900 block">1. Categoría del Suceso</label>
                    <span class="text-[8px] text-red-500 font-bold uppercase">Requerido</span>
                  </div>
                  <div class="w-full bg-white border border-dust-grey/50 rounded px-2 py-1 text-[10px] text-slate-400 flex justify-between items-center">
                    <span>Selecciona una opción...</span>
                    <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>

                <!-- Field 2: Description -->
                <div class="bg-floral-white/50 border border-dust-grey/40 p-2.5 rounded-lg">
                  <label class="text-[10px] font-bold text-slate-900 block mb-1">2. Describe lo sucedido</label>
                  <div class="w-full bg-white border border-dust-grey/50 rounded px-2 py-2 text-[10px] text-slate-300 min-h-[45px]">
                    Escribe detalles, fechas, nombres involucrados...
                  </div>
                </div>

                <!-- Target Drop Area (Dashed Green box) -->
                <div class="border-2 border-dashed border-emerald-400/80 bg-emerald-50/20 rounded-lg p-3 text-center text-[9px] text-emerald-800 font-medium flex items-center justify-center gap-1.5 animate-pulse">
                  <svg class="h-4.5 w-4.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                  <span>Soltar bloque aquí para agregar campo</span>
                </div>
              </div>
            </div>

            <!-- Canvas footer -->
            <div class="pt-3 border-t border-slate-100 flex items-center justify-between">
              <span class="text-[8px] text-slate-400">Paso 1 de 3: Identificación</span>
              <button class="px-3 py-1 bg-almond-cream text-slate-900 text-[10px] font-semibold rounded shadow-2xs hover:bg-almond-cream-hover transition">
                Siguiente
              </button>
            </div>
          </div>

          <!-- Dragged Element Overlapping (Simulation) -->
          <div class="absolute top-[52%] left-[28%] sm:left-[35%] rotate-3 bg-white border-2 border-emerald-500 rounded-xl p-3 shadow-xl text-[11px] text-slate-800 w-44 sm:w-48 flex items-center gap-2 pointer-events-none z-30 animate-bounce">
            <svg class="h-4.5 w-4.5 text-emerald-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            <div class="flex-grow truncate">
              <strong class="font-bold block text-[10px]">Carga de Evidencia</strong>
              <span class="text-[8px] text-slate-400 block truncate">Suelte en área punteada</span>
            </div>
            
            <!-- Mouse hand cursor SVG indicator -->
            <svg class="h-5 w-5 text-emerald-600 absolute -bottom-3 -right-2 transform rotate-12 drop-shadow-md" viewBox="0 0 24 24" fill="currentColor">
              <path d="M7 11h-1v-2c0-.55.45-1 1-1s1 .45 1 1v2zm4 0h-1v-3c0-.55.45-1 1-1s1 .45 1 1v3zm4 0h-1v-3c0-.55.45-1 1-1s1 .45 1 1v3zm4 0h-1v-5c0-.55.45-1 1-1s1 .45 1 1v5zm-14.7 3.3l4.7 4.7c.37.37.88.58 1.41.58h6.59c1.1 0 2-.9 2-2v-5.2c0-.38-.22-.72-.56-.88l-4.5-2.2c-.37-.18-.8-.11-1.1.18l-1.84 1.84v-4.14c0-1.1-.9-2-2-2s-2 .9-2 2v9.38l-3.32-1.66c-.46-.23-1.01-.13-1.37.24-.37.37-.4.96-.06 1.36z"/>
            </svg>
          </div>

        </div>

        <!-- Float badge "UX de confianza" -->
        <div class="absolute -bottom-5 right-6 bg-white/95 backdrop-blur-sm border border-slate-200 p-2.5 rounded-xl shadow-md flex items-center gap-2 max-w-[210px] z-20">
          <div class="h-6 w-6 rounded-lg bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-600">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div class="text-[9px] font-mono text-slate-600 leading-tight">
            <strong class="text-slate-900 font-bold block">UX Centrada en Confianza</strong>
            Mitiga el temor al reporte
          </div>
        </div>

      </div>

    </div>
  </div>
</section>
